APP_NAME="VK Hotel"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.onrender.com

# ========================================
# LOGGING & MONITORING
# ========================================
LOG_CHANNEL=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ========================================
# DATABASE CONFIGURATION
# ========================================
# For Production (PostgreSQL on Render)
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=vk_hotel
DB_USERNAME=postgres
DB_PASSWORD=

# ========================================
# CACHE & SESSION CONFIGURATION
# ========================================
BROADCAST_DRIVER=log
CACHE_DRIVER=array
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# ========================================
# REDIS (Optional - for better performance)
# ========================================
MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ========================================
# MAIL CONFIGURATION (Mailtrap or SendGrid)
# ========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@vkhotel.com"
MAIL_FROM_NAME="${APP_NAME}"

# ========================================
# AWS S3 (Optional - for file storage)
# ========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ========================================
# PAYMENT GATEWAY - STRIPE (Optional)
# ========================================
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ========================================
# PAYMENT GATEWAY - PAYPAL (Optional)
# ========================================
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# ========================================
# BROADCASTING (Real-time features)
# ========================================
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# ========================================
# VITE BUILD VARIABLES
# ========================================
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ========================================
# API RATE LIMITING
# ========================================
API_RATE_LIMIT=60
API_RATE_LIMIT_WINDOW=1

# ========================================
# SECURITY
# ========================================
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
SESSION_DOMAIN=.onrender.com

# ========================================
# GOOGLE ANALYTICS (Optional)
# ========================================
GOOGLE_ANALYTICS_ID=

# ========================================
# SENTRY ERROR TRACKING (Optional)
# ========================================
SENTRY_LARAVEL_DSN=

# ========================================
# FEATURE FLAGS
# ========================================
FEATURE_PAYMENT_ENABLED=true
FEATURE_SMS_ALERTS=false
FEATURE_TWO_FACTOR_AUTH=true
